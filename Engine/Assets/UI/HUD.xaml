<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d"
  xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
  d:DesignWidth="1920" d:DesignHeight="1080">

    <Grid x:Name="LayoutRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="298*"/>
            <RowDefinition Height="484*"/>
            <RowDefinition Height="298*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200*"/>
            <ColumnDefinition Width="746*"/>
            <ColumnDefinition Width="334*"/>
        </Grid.ColumnDefinitions>

        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Offset="0"    Color="#000089FF"/>
                <GradientStop Offset="0.05" Color="#003FA7FF"/>
                <GradientStop Offset="1"    Color="#00123859"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Viewbox x:Name="HealtBar_Viewport" Grid.Row="0" Grid.Column="0" Stretch="Uniform">
            <Grid Width="50" Height="68" Margin="0,6,50,26">
                
                <Grid Width="50" VerticalAlignment="Bottom" Height="68">
                    <Rectangle x:Name="HealthFill" 
                               Fill="Red" 
                               Width="50" 
                               Height="68" 
                               VerticalAlignment="Bottom">
                        <Rectangle.OpacityMask>
                            <ImageBrush ImageSource="Textures/HealthBar_Interior.png" 
                                        Stretch="Fill" 
                                        AlignmentY="Bottom"
                                        ViewportUnits="Absolute"
                                        Viewport="0,0,50,68"/>
                        </Rectangle.OpacityMask>
                    </Rectangle>
                </Grid>

                <Image x:Name="HealthBar_Image" Source="Textures/Health_Bar.png" Stretch="Fill"/>
            </Grid>
        </Viewbox>

        <Viewbox x:Name="Player_Image" Stretch="Uniform" Grid.Row="0" Grid.Column="0">
            <Image x:Name="mask" Width="100" Height="100" Source="Textures/HUD_Player.png"/>
        </Viewbox>

        <Viewbox x:Name="StaminaBar_Viewport" Grid.Row="0" Grid.Column="0" Stretch="Uniform">
            <Grid Width="50" Height="68" Margin="50,6,0,26" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <ScaleTransform ScaleX="-1"/>
                </Grid.RenderTransform>

                <Grid Width="50" VerticalAlignment="Bottom" Height="68">
                    <Rectangle x:Name="StaminaFill" 
                               Fill="Yellow" 
                               Width="50" 
                               Height="68" 
                               VerticalAlignment="Bottom">
                        <Rectangle.OpacityMask>
                            <ImageBrush ImageSource="Textures/HealthBar_Interior.png" 
                                        Stretch="Fill" 
                                        AlignmentY="Bottom"
                                        ViewportUnits="Absolute"
                                        Viewport="0,0,50,68"/>
                        </Rectangle.OpacityMask>
                    </Rectangle>
                </Grid>

                <Image x:Name="StaminaBar_Image" Source="Textures/Health_Bar.png" Stretch="Fill"/>
            </Grid>
        </Viewbox>

    </Grid>
</Grid>