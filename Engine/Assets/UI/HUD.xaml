<Grid x:Name="LayoutRoot"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d"
xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
d:DesignWidth="1920" d:DesignHeight="1080">

    <Grid.Background>
        <SolidColorBrush Color="#00000000"/>
    </Grid.Background>

    <Viewbox Stretch="Uniform" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid Width="1920" Height="1080">

            <Grid.RowDefinitions>
                <RowDefinition Height="271*"/>
                <RowDefinition Height="511*"/>
                <RowDefinition Height="298*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="354*"/>
                <ColumnDefinition Width="1327*"/>
                <ColumnDefinition Width="239*"/>
            </Grid.ColumnDefinitions>

            <!-- Imagen del jugador -->
            <Viewbox x:Name="PlayerImage_Viewport" Stretch="Uniform" Grid.Row="0" Margin="0,15,30,0">
                <Image x:Name="PlayerImage" Width="100" Height="100" Source="Textures/HUD_Player.png"/>
            </Viewbox>

            <!-- HealthBar -->
            <Viewbox x:Name="HealthBar_Viewport" Stretch="Uniform" Grid.Row="0" Margin="0,15,30,0">
                <Grid Width="40" Height="74" Margin="0,0,60,26">
                    <Image x:Name="HealthBar_Image" Opacity="0.49" Source="Textures/Health_Bar.png"
                           Width="40" Height="74" VerticalAlignment="Bottom"/>
                    <Grid Width="40" Height="74" VerticalAlignment="Bottom" ClipToBounds="True">
                        <Grid x:Name="HealthGrid" Width="40" Height="74"
                              VerticalAlignment="Bottom"
                              RenderTransformOrigin="0.5,1.0">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <Image x:Name="HealthBar_Interior"
                                   Source="Textures/HealthBar_Interior.png"
                                   Width="40" Height="74"
                                   VerticalAlignment="Bottom"
                                   Stretch="Fill"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Viewbox>

            <!-- StaminaBar -->
            <Viewbox x:Name="StaminaBar_Viewport" Stretch="Uniform" Grid.Row="0" Margin="0,15,30,0">
                <Grid Width="43" Height="56" Margin="2,13,55,31">
                    <Image x:Name="StaminaBar_Image" Opacity="0.49" Source="Textures/Stamina_Bar.png"
                           Width="43" Height="56" VerticalAlignment="Bottom"/>
                    <Grid Width="43" Height="56" VerticalAlignment="Bottom" ClipToBounds="True">
                        <Grid x:Name="StaminaGrid" Width="43" Height="56"
                              VerticalAlignment="Bottom"
                              RenderTransformOrigin="0.5,1.0">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <Image x:Name="StaminaBar_Interior"
                                   Source="Textures/StaminaBar_Interior.png"
                                   Width="31" Height="56"
                                   Margin="6,0"
                                   VerticalAlignment="Bottom"
                                   Stretch="Fill"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Viewbox>

            <!-- Pocion -->
            <Viewbox x:Name="Potion" Grid.Row="0" Stretch="Uniform" Grid.Column="2" Margin="61,24,34,98">
                <Grid RenderTransformOrigin="0.5,0.5" Width="54" Height="66">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Grid.RenderTransform>
                    <Image x:Name="PotionContainer" Source="Textures/PotionContainer.PNG"/>
                    <TextBlock x:Name="PotionsNumber" TextWrapping="Wrap" Text="0" Foreground="#FFFFFFFF"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="29,0,0,34" FontFamily="Arial"/>
                    <Image x:Name="Potion_Image" Margin="4,14,8,10" RenderTransformOrigin="0.5,0.5"
                           Source="Textures/HealthPotion.png">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                </Grid>
            </Viewbox>

        </Grid>
    </Viewbox>

</Grid>
