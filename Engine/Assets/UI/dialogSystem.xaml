<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d"
  xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
  xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
  d:DesignWidth="1280" d:DesignHeight="720">

    <Grid.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Storyboard x:Key="ContinueBounce" RepeatBehavior="Forever">
                <DoubleAnimationUsingKeyFrames
                    Storyboard.TargetName="ContinueIcon"
                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
                    <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.45" Value="5">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.9" Value="0">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>

        </ResourceDictionary>
    </Grid.Resources>

    <Grid.Background>
        <SolidColorBrush Color="Transparent"/>
    </Grid.Background>

    <Viewbox Stretch="Uniform"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

        <Grid x:Name="LayoutRoot" Width="1280" Height="720">

            <!-- ===== PORTRAIT: fuera de la caja, anclado abajo-izquierda ===== -->
            <!-- Controlado por Lua via SetElementVisibility en los Border -->
            <Grid x:Name="DialogBox"
                  VerticalAlignment="Bottom"
                  HorizontalAlignment="Left"
                  Width="1280"
                  Height="420"
                  Margin="0,0,0,0"
                  Visibility="Collapsed">

                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform Y="0"/>
                    </TransformGroup>
                </Grid.RenderTransform>

                <!-- Portrait grande, cuerpo entero, anclado abajo-izquierda -->
                <Grid Width="300" Height="400"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Bottom"
                      Margin="200,0,0,0">
                    <Border x:Name="Portrait_Telemaco" Visibility="Collapsed">
                        <Image Stretch="Uniform"
                               VerticalAlignment="Bottom"
                               HorizontalAlignment="Center"
                               Source="Textures/Telemaco.png"/>
                    </Border>
                    <Border x:Name="Portrait_Atenea" Visibility="Collapsed">
                        <Image Stretch="Uniform"
                               VerticalAlignment="Bottom"
                               HorizontalAlignment="Center"
                               Source="Textures/Atenea.png"/>
                    </Border>
                    <Border x:Name="Portrait_JohnCartel" Visibility="Collapsed">
                        <Image Stretch="Uniform"
                               VerticalAlignment="Bottom"
                               HorizontalAlignment="Center"
                               Source="Textures/Portrait_Placeholder2.png"/>
                    </Border>
                </Grid>

                <!-- Caja de texto: pergamino + texto, a la derecha del portrait -->
                <Grid Width="820" Height="160"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Bottom"
                      Margin="360,0,0,30">

                    <!-- Pergamino de fondo -->
                    <Image Source="Textures/CuadroDialogo.PNG"
                           Stretch="Fill"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"/>

                    <!-- Texto encima del pergamino -->
                    <Grid Margin="75,25,50,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Nombre del personaje -->
                        <TextBlock x:Name="CharacterName"
                                   Grid.Row="0"
                                   Text=""
                                   FontSize="15"
                                   FontWeight="Bold"
                                   FontFamily="Times New Roman"
                                   Margin="0,0,0,5">
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="#FF5C3300"/>
                            </TextBlock.Foreground>
                        </TextBlock>

                        <!-- Texto del diálogo -->
                        <TextBlock x:Name="DialogText"
                                   Grid.Row="1"
                                   Text=""
                                   FontSize="13"
                                   FontFamily="Times New Roman"
                                   FontStyle="Italic"
                                   TextWrapping="Wrap"
                                   LineHeight="20"
                                   VerticalAlignment="Top">
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="#FF3D2200"/>
                            </TextBlock.Foreground>
                        </TextBlock>

                        <!-- Icono continuar -->
                        <TextBlock x:Name="ContinueIcon"
                                   Grid.Row="2"
                                   Text="▼"
                                   FontSize="11"
                                   FontFamily="Times New Roman"
                                   HorizontalAlignment="Right"
                                   Margin="0,0,4,0"
                                   Visibility="Collapsed">
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="#FF7A4A00"/>
                            </TextBlock.Foreground>
                            <TextBlock.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform/>
                                    <RotateTransform/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </TextBlock.RenderTransform>
                            <TextBlock.Triggers>
                                <EventTrigger RoutedEvent="TextBlock.Loaded">
                                    <BeginStoryboard Storyboard="{StaticResource ContinueBounce}"/>
                                </EventTrigger>
                            </TextBlock.Triggers>
                        </TextBlock>

                    </Grid>
                </Grid>

            </Grid>

        </Grid>
    </Viewbox>

</Grid>
